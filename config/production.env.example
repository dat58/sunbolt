# Sunbolt production configuration example.
# Replace every example hostname, credential, and origin before deployment.

SUNBOLT_ENV=production
SUNBOLT_BIND_ADDR=0.0.0.0:3000
SUNBOLT_PUBLIC_URL=https://sunbolt.example.com
SUNBOLT_ALLOWED_ORIGINS=https://sunbolt.example.com

SUNBOLT_DATABASE_URL=postgres://sunbolt:replace-me@postgres.internal:5432/sunbolt
SUNBOLT_DB_MAX_CONNECTIONS=32
SUNBOLT_DB_MIN_CONNECTIONS=2
SUNBOLT_DB_CONNECT_TIMEOUT_SECS=10
SUNBOLT_DB_ACQUIRE_TIMEOUT_SECS=10

SUNBOLT_COOKIE_SECURE=true
SUNBOLT_SESSION_TTL_SECS=28800
SUNBOLT_RECENT_MFA_TTL_SECS=600
SUNBOLT_REQUIRE_TERMINAL_STEP_UP_MFA=true
SUNBOLT_DEV_BOOTSTRAP_ADMIN=false

SUNBOLT_MAX_TERMINAL_SESSIONS=64
SUNBOLT_MAX_TERMINAL_SESSIONS_PER_USER=5
SUNBOLT_MAX_TERMINAL_SESSIONS_PER_NODE=10
SUNBOLT_TERMINAL_IDLE_TIMEOUT_SECS=1800
SUNBOLT_TERMINAL_MAX_DURATION_SECS=28800
SUNBOLT_TERMINAL_DISCONNECT_GRACE_SECS=30
