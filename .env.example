# Sunbolt local development configuration
SUNBOLT_ENV=local
SUNBOLT_BIND_ADDR=127.0.0.1:3000
SUNBOLT_DATABASE_URL=postgres://sunbolt:sunbolt@localhost:5432/sunbolt
SUNBOLT_DB_MAX_CONNECTIONS=16
SUNBOLT_DB_MIN_CONNECTIONS=1
SUNBOLT_DB_CONNECT_TIMEOUT_SECS=10
SUNBOLT_DB_ACQUIRE_TIMEOUT_SECS=10

# Sunbolt agent local development configuration
SUNBOLT_CONTROL_PLANE_URL=http://127.0.0.1:3000
SUNBOLT_AGENT_NODE_NAME=local-agent
# SUNBOLT_AGENT_ENROLLMENT_TOKEN=
